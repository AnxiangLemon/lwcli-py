# LwApi HTTP 服务地址
LWAPI_BASE_URL=http://localhost:8081

# 运维台监听（默认仅本机；需局域网访问可改为 0.0.0.0 并自行加固网络）
LWAPI_WEB_HOST=127.0.0.1
LWAPI_WEB_PORT=26121

# 打包版默认会自动打开浏览器；设为 0 可关闭
# LWAPI_OPEN_BROWSER=0

# 消息同步方式：websocket 或 http
# LWAPI_MSG_SYNC_MODE=websocket

# 自定义插件目录（默认程序旁的 plugins/）
# LWAPI_PLUGINS_DIR=

# 运维台登录 Token（默认 123123；留空则关闭鉴权）
LWAPI_WEB_TOKEN=123123

# 日志（正式上线建议 INFO；排障时可临时 DEBUG）
# LWAPI_LOG_LEVEL=INFO
# LWAPI_LOG_CONSOLE_LEVEL=INFO
# LWAPI_LOG_FILE_LEVEL=INFO
# LWAPI_LOG_ROTATION=10 MB
# LWAPI_LOG_RETENTION=7 days
